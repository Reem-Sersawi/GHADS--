<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ChangePasswordController">
    <center>
        <VBox spacing="20" alignment="CENTER" style="-fx-background-color: #313244; -fx-background-radius: 15;">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>
            
            <Text text="تغيير كلمة المرور" fill="#89b4fa">
                <font>
                    <Font name="System Bold" size="18"/>
                </font>
            </Text>
            
            <VBox spacing="15" minWidth="300">
                <PasswordField fx:id="oldPasswordField" promptText="كلمة المرور الحالية" style="-fx-pref-height: 38;"/>
                <PasswordField fx:id="newPasswordField" promptText="كلمة المرور الجديدة" style="-fx-pref-height: 38;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="تأكيد كلمة المرور الجديدة" style="-fx-pref-height: 38;"/>
            </VBox>
            
            <HBox spacing="15" alignment="CENTER">
                <Button text="حفظ" onAction="#handleSave" style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e; -fx-pref-width: 100;"/>
                <Button text="إلغاء" onAction="#handleCancel" style="-fx-pref-width: 100;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
